{
  "name": "oenivault-ai-backend",
  "version": "0.1.0",
  "private": true,
  "description": "OeniVault AI API — wine inventory, auth, customers",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "tsx src/scripts/seed.ts",
    "simulate:climate": "tsx src/scripts/simulateClimate.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/tests/**/*.test.ts",
    "test:superset": "tsx --test src/tests/phase1.superset.test.ts",
    "test:phase1": "tsx --test src/tests/phase1.regression.test.ts src/tests/phase1.superset.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.19.1",
    "pg": "^8.13.1",
    "socket.io": "^4.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}

# Server
PORT=4000
NODE_ENV=development

# PostgreSQL (local or Supabase connection string)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/oenivault

# JWT — keep access tokens short; optional separate refresh secret
JWT_SECRET=change-me-to-a-long-random-secret
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=14d

# CORS (frontend origin)
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173

# Public signup (set false in production for invite-only)
ALLOW_PUBLIC_SIGNUP=true

# Optional email alerts / password reset
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=alerts@oenivault.ai

# Climate thresholds (°F / %RH) — defaults; per-facility overrides in DB
# CLIMATE_TEMP_WARN_MIN=52
# CLIMATE_TEMP_WARN_MAX=58
# CLIMATE_TEMP_CRIT_MIN=48
# CLIMATE_TEMP_CRIT_MAX=62
# CLIMATE_HUMIDITY_WARN_MIN=55
# CLIMATE_HUMIDITY_WARN_MAX=75
# CLIMATE_HUMIDITY_CRIT_MIN=45
# CLIMATE_HUMIDITY_CRIT_MAX=85

# Optional external wine valuation API (falls back to heuristic)
# VALUATION_API_URL=https://api.example.com/valuate
# VALUATION_API_KEY=

# Reading retention for purge job
# RETENTION_DAYS=90
